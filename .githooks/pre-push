#!/usr/bin/env bash
# Pre-push hook: runs linter and tests before allowing a push.
# Installed automatically by bin/setup.
#
# To skip in an emergency: git push --no-verify

set -e

cd "$(git rev-parse --show-toplevel)"

echo "==> Linting (RuboCop)..."
bin/rubocop --format quiet

echo "==> Running tests..."
bin/rails db:test:prepare test

echo "==> All checks passed."
