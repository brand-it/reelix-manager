#!/usr/bin/env bash
# Pre-push hook: runs all CI checks before allowing a push.
# Installed automatically by bin/setup.
#
# To skip in an emergency: git push --no-verify

set -e

cd "$(git rev-parse --show-toplevel)"

echo "==> Linting code with RuboCop..."
bin/rubocop -f github

echo "==> Scanning for common Rails security vulnerabilities with Brakeman..."
bin/brakeman --no-pager

echo "==> Scanning for known security vulnerabilities in gems..."
bin/bundler-audit

echo "==> Scanning for security vulnerabilities in JavaScript dependencies..."
bin/importmap audit

echo "==> Running tests..."
bin/rails db:test:prepare test

echo "==> Running system tests..."
bin/rails db:test:prepare test:system

echo "==> All checks passed."
