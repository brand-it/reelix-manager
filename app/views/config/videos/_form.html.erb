<div class="row">
  <div class="col-md-8 col-lg-6">
    <%= simple_form_for config_video, url: url, method: config_video.persisted? ? :patch : :post do |f| %>
      <%= f.error_notification %>
      <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Video Settings</h5>
        </div>
        <div class="card-body">
          <%= f.input :settings_movie_path,
                      label: "Movie Path",
                      hint: "Directory where uploaded Movies files will be stored" %>
                    
          <%= f.input :settings_tv_path,
                      label: "TV Path",
                      hint: "Directory where uploaded TV shows will be stored"
          %>

          <div class="mb-3" data-controller="reveal">
            <%= f.label :settings_tmdb_api_key, "TMDB API Key", class: "form-label" %>
            <div class="input-group">
              <%= f.input_field :settings_tmdb_api_key,
                                as: :password,
                                value: f.object.settings_tmdb_api_key,
                                data: { reveal_target: "field" },
                                class: "form-control",
                                autocomplete: "off" %>
              <button class="btn btn-outline-secondary"
                      type="button"
                      data-reveal-target="toggle"
                      data-action="reveal#toggle"
                      data-reveal-show-label="Show"
                      data-reveal-hide-label="Hide">Show</button>
            </div>
            <%= f.full_error :settings_tmdb_api_key, class: "invalid-feedback d-block" %>
            <%= f.hint "TheMovieDB API key for movie/TV metadata lookups — <a href='https://www.themoviedb.org/settings/api' target='_blank' rel='noopener noreferrer'>Get your API key here</a>.".html_safe %>
          </div>

          <%= f.input :settings_processed_path,
                      label: "Processed Path",
                      hint: "Output directory for post-processed and organized files" %>

          <%= f.input :settings_scan_hidden_directories,
                      as: :boolean,
                      label: "Scan hidden directories",
                      hint: "Include directories starting with a dot (.) when scanning the library" %>
        </div>
        <div class="card-footer">
          <%= f.button :submit, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
