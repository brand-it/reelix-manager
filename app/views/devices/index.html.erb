<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0">Authorized Devices</h4>
</div>

<% if @tokens.empty? && @device_grants.empty? %>
  <div class="alert alert-info">No authorized devices yet.</div>
<% else %>
  <div class="table-responsive">
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <% if current_user.admin? %>
            <th>User</th>
          <% end %>
          <th>Application</th>
          <th>Authorized</th>
          <th>Expires</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @device_grants.each do |grant| %>
          <tr>
            <% if current_user.admin? %>
              <td><%= User.find_by(id: grant.resource_owner_id)&.email || "Unknown" %></td>
            <% end %>
            <td><%= grant.application&.name || "—" %></td>
            <td><%= grant.created_at.strftime("%b %-d, %Y") %></td>
            <td>
              <%= grant.created_at.advance(seconds: grant.expires_in).strftime("%b %-d, %Y") %>
            </td>
            <td><span class="badge bg-warning text-dark">Pending</span></td>
            <td>
              <%= button_to "Cancel", grant_devices_path(id: grant.id),
                            method: :delete,
                            class: "btn btn-sm btn-outline-danger",
                            data: { turbo_confirm: "Cancel this pending device authorization?" } %>
            </td>
          </tr>
        <% end %>

        <% @tokens.each do |token| %>
          <tr>
            <% if current_user.admin? %>
              <td><%= token.user&.email || "Unknown" %></td>
            <% end %>
            <td><%= token.application&.name || "—" %></td>
            <td><%= token.created_at.strftime("%b %-d, %Y") %></td>
            <td>
              <% if token.expires_in %>
                <%= token.created_at.advance(seconds: token.expires_in).strftime("%b %-d, %Y") %>
              <% else %>
                Never
              <% end %>
            </td>
            <td>
              <% if token.revoked? %>
                <span class="badge bg-secondary">Revoked</span>
              <% elsif token.expired? %>
                <span class="badge bg-warning text-dark">Expired</span>
              <% else %>
                <span class="badge bg-success">Active</span>
              <% end %>
            </td>
            <td>
              <% unless token.revoked? %>
                <%= button_to "Revoke", device_path(token),
                              method: :delete,
                              class: "btn btn-sm btn-outline-danger",
                              data: { turbo_confirm: "Revoke access for this device?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
