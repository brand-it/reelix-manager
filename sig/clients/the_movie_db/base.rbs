module TheMovieDb
  class Base
    @api_key: untyped

    @language: untyped

    @results: untyped

    # Only enable Faraday logging in local environments to avoid leaking the api_key
    # in query parameters into production logs.
    @connection: untyped

    HOST: "api.themoviedb.org"

    VERSION: "3"

    CACHE_TTL: untyped

    CACHE_NAMESPACE: "the_movie_db"

    #  (?api_key: String?, ?language: String?) -> void
    def initialize: (?api_key: untyped?, ?language: untyped?) -> void

    # Validates that the given API key can reach the TMDB API.
    # Returns true/false — safe to call from model validations.
    #  (api_key: String) -> bool
    def self.ping: (api_key: untyped) -> untyped

    #  (?use_cache: bool, ?object_class: Class) -> untyped
    def results: (?use_cache: bool, ?object_class: untyped) -> untyped

    #  () -> bool
    def ping: () -> untyped

    private

    #  () -> URI::HTTPS
    def ping_uri: () -> untyped

    #  (?object_class: Class) -> ::Hash[String, untyped]
    def cache_get: (?object_class: untyped) -> untyped

    #  (?object_class: Class) -> ::Hash[String, untyped]
    def get: (?object_class: untyped) -> untyped

    #  () -> Faraday::Connection
    def connection: () -> untyped

    #  () -> URI::HTTPS
    def uri: () -> untyped

    #  () -> String
    def path: () -> untyped

    #  () -> ::Hash[untyped, untyped]
    def query_params: () -> untyped

    # Reads the API key from Config::Video; may be overridden by passing api_key: at instantiation.
    # Visit https://www.themoviedb.org/settings/api to obtain a key.
    #  () -> String
    def api_key: () -> untyped

    # Pass an ISO 639-1 value to display translated data (e.g. "en-US").
    #  () -> String
    def language: () -> untyped
  end
end
