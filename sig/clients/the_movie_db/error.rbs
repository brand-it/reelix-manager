module TheMovieDb
  # Raised when the TMDB API returns a non-2xx response.
  class Error < StandardError
    # The raw Faraday response object.
    attr_reader object: Faraday::Response

    # Parsed JSON body, or the raw body string if JSON parsing fails.
    attr_reader body: ::Hash[String, untyped] | String?

    def initialize: (Faraday::Response object) -> void

    private

    def parse_body: (String? raw_body) -> (::Hash[String, untyped] | String?)
    def build_message: (Faraday::Response object) -> String
  end
end
