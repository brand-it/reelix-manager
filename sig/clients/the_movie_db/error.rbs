module TheMovieDb
  class Error < StandardError
    @object: untyped

    @body: untyped

    attr_reader object: untyped

    attr_reader body: untyped

    #  (untyped object) -> void
    def initialize: (untyped object) -> void

    private

    #  (String? raw_body) -> untyped
    def parse_body: (untyped raw_body) -> untyped

    #  (untyped object) -> String
    def build_message: (untyped object) -> untyped
  end
end
