# Mixin for GraphQL resolvers and mutations that enforces Doorkeeper token scopes.
# graphql-ruby's `context` is untyped — we accept that limitation here.
module ScopeEnforceable
  # Provided by the including GraphQL resolver/mutation class via graphql-ruby.
  def context: () -> GraphQL::Query::Context

  def can_search?: () -> bool
  def require_search!: () -> void

  def can_upload?: () -> bool
  def require_upload!: () -> void

  private

  # True when the request is authenticated via a Devise session (no Doorkeeper token).
  def session_user?: () -> bool
end
