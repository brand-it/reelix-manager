class Config
  # Hash-like wrapper around a JSON settings blob. Keys are always strings or
  # symbols (via HashWithIndifferentAccess under the hood).
  class Serializer
    @data: ::Hash[String | Symbol, untyped]

    def self.load: (String? json) -> Config::Serializer

    def initialize: (?::Hash[String | Symbol, untyped] data) -> void

    def []: (String | Symbol key) -> untyped
    def []=: (String | Symbol key, untyped value) -> untyped
    def key?: (String | Symbol key) -> bool

    # Returns the underlying hash so that Setting#contains_key? can introspect it.
    def marshal_dump: () -> ::Hash[String | Symbol, untyped]

    def to_h: () -> ::Hash[String | Symbol, untyped]
  end
end
