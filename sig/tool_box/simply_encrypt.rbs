# AES-256-CBC encryption/decryption mixin used by Config::Setting.
module SimplyEncrypt
  MODE: String
  KEY: String

  # Returns [encrypted_data, iv], both URL-safe Base64 encoded.
  # Returns [nil, nil] when data is blank.
  def encrypt: (String? data) -> [String?, String?]

  # Returns the decrypted plaintext, or nil when data/iv is blank or decryption fails.
  def decrypt: (String? data, String? iv) -> String?

  private

  def encode: (String string) -> String
  def decode: (String string) -> String
end
